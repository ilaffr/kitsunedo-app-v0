################################################################################
# Kitsune-dō — Environment Variables
#
# Local Docker:  cp .env.example .env.docker  →  docker compose --env-file .env.docker up -d
# Production:    cp .env.example .env.prod    →  fill in real values on VPS
# Dev (no Docker): keep .env for Supabase Cloud (already configured)
#
# Generating ANON_KEY / SERVICE_ROLE_KEY from JWT_SECRET:
#   https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
################################################################################

# ── Supabase Cloud (dev without Docker) ──────────────────────────────────────
VITE_SUPABASE_PROJECT_ID="oslayutgixhvvelmbkxz"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://oslayutgixhvvelmbkxz.supabase.co"

# ── Self-hosted Supabase (Docker local / VPS) ─────────────────────────────────

# Database
POSTGRES_PASSWORD=change-me-super-secret-db-password

# JWT — must be at least 32 characters
JWT_SECRET=change-me-super-secret-jwt-token-at-least-32-chars

# API keys derived from JWT_SECRET (generate at link above)
ANON_KEY=your-anon-jwt-here
SERVICE_ROLE_KEY=your-service-role-jwt-here

# Realtime secret — generate with: openssl rand -hex 64
SECRET_KEY_BASE=change-me-64-char-hex-secret

# URLs
SITE_URL=http://localhost:8080
API_EXTERNAL_URL=http://localhost:8000
# Prod: SITE_URL=https://yourdomain.com  API_EXTERNAL_URL=https://yourdomain.com

ADDITIONAL_REDIRECT_URLS=
DISABLE_SIGNUP=false

# SMTP (leave blank locally — GOTRUE_MAILER_AUTOCONFIRM=true skips email)
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Kitsune-do

# ── AI (Google Gemini) ───────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
